# Lexis AI Assistant - Environment Configuration
# Copy this to .env and fill in your values

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# REQUIRED CONFIGURATION
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Mistral API Key
# Get from: https://console.mistral.ai/
# Required for LLM and embeddings
MISTRAL_API_KEY=your_mistral_api_key_here

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# OPTIONAL: ADVANCED CONFIGURATION
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Streamlit Configuration
STREAMLIT_LOGGER_LEVEL=info
STREAMLIT_CLIENT_MAXUPLOADSIZE=200
STREAMLIT_SERVER_MAXUPLOADSIZE=200

# Database Configuration
# Leave empty for default local storage
CHROMA_DB_PATH=./chroma_db
CHAT_HISTORY_PATH=./data/chat_history.json
ANALYTICS_PATH=./data/analytics.json

# Model Configuration
# Only change if you have access to different Mistral models
# LLM_MODEL=mistral-small-2506
# EMBEDDING_MODEL=mistral-embed

# Performance Tuning
# Adjust these based on your hardware
# CHUNK_SIZE=1500
# CHUNK_OVERLAP=400
# RETRIEVER_K=8
# MAX_CONTEXT_LENGTH=5000

# Feature Flags
# ENABLE_ANALYTICS=true
# ENABLE_LOGGING=true
# ENABLE_CHAT_PERSISTENCE=true

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# DEPLOYMENT-SPECIFIC CONFIGURATION
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# For Streamlit Cloud: Leave above and use Secrets management
# For Docker: Pass as environment variables
# For Local: Use .env file (this file)

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# DEBUGGING (development only)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Debug mode
# DEBUG=false

# Verbose logging
# VERBOSE=false

# Profile performance
# PROFILE=false
